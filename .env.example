# Canonical public origin for this deployment (no trailing slash).
# Set in Cloudflare Pages / Vercel / CI per site. Used for canonical, Open Graph, sitemap, RSS, JSON-LD.
# If unset, falls back to lib/site.config.ts → seo.siteUrl.
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional. Amazon Associates tag for /products “Search … on Amazon” links (see lib/amazon-search-url.ts).
# NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=your-tag-20

# Optional. Google Analytics 4 Measurement ID (GA4 → Admin → Data streams → copy G-XXXXXXXXXX). Set in Cloudflare Pages env for production builds.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
